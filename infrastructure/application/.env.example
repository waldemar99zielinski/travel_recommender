# Published host ports
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Backend API configuration
API_ENV=production
API_LOG_LEVEL=info
API_CORS_ALLOW_ORIGINS=http://localhost:8080

# Backend storage configuration
STORAGE_ENGINE__DB_URL=postgresql+psycopg://postgres:postgres@replace-me:5432/recommender
STORAGE_ENGINE__ECHO=false
STORAGE_ENGINE__POOL_PRE_PING=true
STORAGE_ENGINE__POOL_SIZE=5
STORAGE_ENGINE__MAX_OVERFLOW=10
STORAGE_MIGRATIONS__ENABLED=true
STORAGE_MIGRATIONS__LOCK_KEY=540021

# Backend LLM configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=2
LLM_API_KEY=
LLM_BASE_URL=
TAVILY_API_KEY=

# Backend embeddings configuration
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL_NAME=nomic-embed-text
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=

# Frontend runtime configuration
APP_ENVIRONMENT=production
API_BASE_URL=http://localhost:8000
REGIONS_DATA_URL=/regions.json
